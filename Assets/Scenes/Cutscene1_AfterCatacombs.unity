--- !u!114 &1410614202
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1410614201}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3e62d9a51c5d07c4d9f7693e72174efd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneController
  panels:
  - backgroundSprite: {fileID: -8927261817362051821, guid: 43705953ed3031e45be587547229d96a, type: 3}
    speakerName: Ember Spy
    bodyText: "You have done well, Siera. The catacombs are behind you, and now you
      stand within the castle\u2019s walls. Outside, our members march toward the
      gates. When you break the curse they will enter, and together we will cleanse
      whatever evil lingers here."
    characterPortrait: {fileID: 6729837620646145182, guid: f3498b9441ddc9b4ebc4a72270c2bf5a, type: 3}
  - backgroundSprite: {fileID: 2602332293906980097, guid: a3d21c3121db6b540b135cfcee5e4800, type: 3}
    speakerName: Siera
    bodyText: " I can feel the castle watching me. Every step feels heavier\u2026
      but I will not falter. Tell me what lies ahead?"
    characterPortrait: {fileID: -6619754007301896981, guid: e15d77dd72b0a4f499b553ec15e516bf, type: 3}
  - backgroundSprite: {fileID: -8679589492554895114, guid: 51954f5964e8d504ebfe2c256757d6ee, type: 3}
    speakerName: Ember Spy
    bodyText: "Danger waits. The castle senses an intruder, an unknown presence stirs
      within its halls. It may fight back. Beware of the bounded creatures that roam
      here. They move as one, bound to the castle\u2019s hive mind. Rakel is a mere
      puppet to the castles will.."
    characterPortrait: {fileID: 6729837620646145182, guid: f3498b9441ddc9b4ebc4a72270c2bf5a, type: 3}
  - backgroundSprite: {fileID: 7333238413658297962, guid: c9c9c207015ea1f49ab50b57f6a3f8ab, type: 3}
    speakerName: Siera
    bodyText: "Then I\u2019ll keep my eyes sharp. If the castle wants to fight, it
      will find me ready."
    characterPortrait: {fileID: -6619754007301896981, guid: e15d77dd72b0a4f499b553ec15e516bf, type: 3}
  nextSceneName: Level2_Gardens
